{
  "name": "md-table-conv",
  "displayName": "Markdow Table Generator",
  "description": "Форматирует текст в Markdow таблицу",
  "version": "1.0.0",
  "engines": {
    "vscode": "^1.85.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/plushhero/Markdown-Table-Converter"
  },
  "bugs": {
    "url": "https://github.com/plushhero/Markdown-Table-Converter/issues"
  },
  "homepage": "https://github.com/plushhero/Markdown-Table-Converter/blob/master/README.md",
  "categories": [
    "Formatters",
    "Other"
  ],
  "activationEvents": [],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "md-table-conv.convertToTable",
        "title": "Convert to Markdown Table",
        "category": "MD Table"
      }
    ],
    "keybindings": [
      {
        "command": "md-table-conv.convertToTable",
        "key": "ctrl+shift+/",
        "mac": "Cmd+Shift+/",
        "when": "editorTextFocus && !editorReadonly"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "npm run check-types && npm run lint && node esbuild.js",
    "watch": "npm-run-all -p watch:*",
    "watch:esbuild": "node esbuild.js --watch",
    "watch:tsc": "tsc --noEmit --watch --project tsconfig.json",
    "package": "npm run check-types && npm run lint && node esbuild.js --production",
    "compile-tests": "tsc -p . --outDir out",
    "watch-tests": "tsc -p . -w --outDir out",
    "pretest": "npm run compile-tests && npm run compile && npm run lint",
    "check-types": "tsc --noEmit",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/vscode": "^1.85.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "typescript-eslint": "^8.56.1",
    "eslint": "^9.39.3",
    "esbuild": "^0.27.3",
    "npm-run-all": "^4.1.5",
    "typescript": "^5.9.3",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2"
  }
}